# frontend/.env.example
# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit it.
# =========================================================

# =========================================================
# API CONNECTION
# =========================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
# URL of the backend Express server.
# Next.js proxies /api/* calls here in development.
# Production: https://api.m2ilms.com

NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
# URL of the Socket.io server (same as API in most cases).
# Must match exactly including protocol and port.
# Production: https://api.m2ilms.com

# =========================================================
# APP METADATA
# =========================================================
NEXT_PUBLIC_APP_NAME=M2i LMS
# Displayed in the browser title bar and various UI elements.

NEXT_PUBLIC_APP_ENV=development
# Options: development | staging | production
# Used to show environment indicator in the UI.
# Prevents accidentally treating staging as production.

# =========================================================
# FEATURE FLAGS (Phase Two — leave false for Phase One)
# =========================================================
# NEXT_PUBLIC_ENABLE_FORUM=false
# NEXT_PUBLIC_ENABLE_CAREER_PATH=false
# NEXT_PUBLIC_ENABLE_COMPANY_PORTAL=false