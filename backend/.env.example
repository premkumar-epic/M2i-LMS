# backend/.env.example
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is in .gitignore.
# =========================================================

# =========================================================
# SERVER
# =========================================================
NODE_ENV=development
# Options: development | test | production

PORT=3001
# The port the Express server listens on.
# Frontend proxies /api calls here.

CORS_ORIGIN=http://localhost:3000
# The frontend URL. Must exactly match including protocol.
# Production example: https://app.m2ilms.com

# =========================================================
# DATABASE (PostgreSQL)
# =========================================================
DATABASE_URL=postgresql://m2i_user:m2i_dev_password@localhost:5432/m2i_lms_dev
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Dev: uses Docker (see docker-compose.yml)
# Production: use AWS RDS connection string
# Test: change database name to m2i_lms_test

DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
# Connection pool size. Increase for production.
# Rule of thumb: max = (number of CPU cores * 2) + 1

# =========================================================
# REDIS
# =========================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Leave REDIS_PASSWORD empty for local dev (no auth).
# Production: set a strong password.

# =========================================================
# JWT AUTHENTICATION
# =========================================================
# Generate secrets with: openssl rand -base64 64
# JWT_SECRET and JWT_REFRESH_SECRET MUST be different values.
# Minimum 32 characters each.
JWT_SECRET=
JWT_REFRESH_SECRET=

JWT_ACCESS_EXPIRY=1h
# How long access tokens last.
# Short = more secure, more frequent refreshes.
# Recommended: 1h for production, 24h for development.

JWT_REFRESH_EXPIRY=7d
# How long refresh tokens last.
# Users are logged out after this period of inactivity.

# =========================================================
# AWS S3 (File Storage)
# =========================================================
AWS_REGION=ap-south-1
# Mumbai region — closest to India.
# Change to your preferred region.

AWS_ACCESS_KEY_ID=
# IAM user access key with S3 read/write permissions.
# For development: use placeholder values below if
# you do not need real file uploads:
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

AWS_SECRET_ACCESS_KEY=
# IAM user secret key.
# For development: wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

S3_BUCKET_NAME=m2i-lms-content-dev
# Your S3 bucket name.
# Naming convention: m2i-lms-content-{env}

CLOUDFRONT_DOMAIN=cdn-dev.m2ilms.com
# Your CloudFront distribution domain.
# Used to build CDN URLs for uploaded files.
# For development with no CloudFront: use s3.amazonaws.com/{bucket}

# =========================================================
# MUX LIVE STREAMING
# =========================================================
MUX_TOKEN_ID=
# Get from: dashboard.mux.com → Settings → API Access Tokens
# Leave empty for development if not testing live streaming.

MUX_TOKEN_SECRET=
# Paired with MUX_TOKEN_ID.
# Never commit this value.

STREAMING_PROVIDER=MUX
# Options: MUX | AGORA
# MUX is the default and recommended provider.

# =========================================================
# AI — OLLAMA (Quiz Generation)
# =========================================================
OLLAMA_URL=http://localhost:11434
# URL of the Ollama service.
# For separate AI instance: http://ai-server-ip:11434

OLLAMA_MODEL=mistral:7b-instruct-v0.2-q4_K_M
# The model to use for quiz generation.
# Must be pulled first: ollama pull mistral:7b-instruct-v0.2-q4_K_M
# Alternative: llama2:7b (lower quality instruction following)
# Upgrade option: mistral:7b-instruct-v0.2 (fp16, needs 8GB VRAM)

OLLAMA_TIMEOUT_MS=120000
# How long to wait for Ollama to respond before timing out.
# Increase if generation is slow on CPU: 300000 (5 minutes)

# =========================================================
# AI — WHISPER (Transcription)
# =========================================================
WHISPER_MODEL=medium
# Options: tiny | base | small | medium | large | large-v2
# Development: tiny (fast, low accuracy)
# Production: medium (good balance)
# High accuracy: large-v2 (requires 10GB+ VRAM)

WHISPER_LANGUAGE=en
# Language of lecture audio.
# Options: en | hi | ta | te | kn | mr | ... (ISO 639-1)
# Use "auto" for automatic language detection (slower).

WHISPER_FP16=False
# Set to True if using a NVIDIA GPU.
# Reduces VRAM usage and speeds up transcription.
# Leave False for CPU-only or Apple Silicon.

TEMP_AUDIO_DIR=/tmp/m2i_audio
# Directory for temporary audio files during transcription.
# Must be writable by the Node.js process.
# Files are deleted after transcription completes.

# =========================================================
# LOGGING
# =========================================================
LOG_LEVEL=debug
# Options: error | warn | info | http | verbose | debug | silly
# Production: info
# Development: debug (shows all Prisma queries)

# =========================================================
# EMAIL (Phase Two — leave empty for Phase One)
# =========================================================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=noreply@m2ilms.com
# SMTP_FROM_NAME=M2i LMS

# =========================================================
# SENTRY (Phase Two — leave empty for Phase One)
# =========================================================
# SENTRY_DSN=